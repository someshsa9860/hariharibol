# ──────────────────────────────────────────────────────────────────────────────
# HariHariBol Backend — Environment Variables
# Copy this file: cp .env.example .env
# NEVER commit the .env file — it contains secrets!
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# APP_MODE: api | socket | worker
APP_MODE=api
APP_URL=http://localhost:3001

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://sanatan:sanatan_dev_password@localhost:5432/sanatan

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL takes precedence over REDIS_HOST/PORT when set
# REDIS_URL=redis://localhost:6379

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_dev_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_dev_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_web_client_secret

# ── Apple Sign-In ─────────────────────────────────────────────────────────────
# Get credentials from: https://developer.apple.com/account/
APPLE_CLIENT_ID=com.your-company.hariharibol
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END PRIVATE KEY-----"

# ── AI Providers ──────────────────────────────────────────────────────────────
# Preferred provider: gemini | openai | claude
AI_PROVIDER=gemini

# Google Gemini (preferred — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-your_openai_api_key

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── Firebase / FCM Push Notifications ─────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_KEY\n-----END PRIVATE KEY-----"
# Alternative: path to downloaded service account JSON
# FCM_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# Legacy FCM server key (for direct HTTP v1 if not using Admin SDK)
FCM_SERVER_KEY=your_fcm_server_key

# ── Storage ───────────────────────────────────────────────────────────────────
# Provider: local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# AWS S3 (when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
S3_BUCKET=hariharibol-dev
S3_ENDPOINT=
CDN_URL=

# ── Email Service ─────────────────────────────────────────────────────────────
# Provider: resend | sendgrid | smtp
EMAIL_SERVICE=resend
EMAIL_FROM=noreply@hariharibol.com

# Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key

# SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# SMTP (generic)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# ── Apple Push Notifications (APNs) ───────────────────────────────────────────
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_APNS_KEY\n-----END PRIVATE KEY-----"
APNS_PRODUCTION=false

# ── CORS & Origins ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_PANEL_URL=http://localhost:3000
ADMIN_JWT_SECRET=CHANGE_ME_admin_secret_at_least_32_chars

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Monitoring & Observability ─────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | log | debug | verbose
LOG_LEVEL=debug
