# ──────────────────────────────────────────────────────────────────────────────
# BACKEND — production environment (lives at /var/www/server/backend/.env)
# Copy to .env and fill in real values. NEVER commit .env.
# Secret KEY FILES (firebase json, apple .p8, etc.) go in ./security/ and are
# mounted into the container at /app/security/ — reference them by that path.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_MODE=api
APP_URL=http://ec2-13-206-188-46.ap-south-1.compute.amazonaws.com:3001

# ── Postgres (used by docker-compose to create the DB container) ───────────────
POSTGRES_USER=hariharibol
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=hariharibol

# ── Database connection (API → postgres container over the compose network) ───
DATABASE_URL=postgresql://hariharibol:CHANGE_ME_strong_db_password@postgres:5432/hariharibol

# ── Redis (API → redis container over the compose network) ────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT (generate: openssl rand -base64 64) ───────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID_IOS=your_ios_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=your_android_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=your_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_web_client_secret
# Service account JSON (mounted from ./security/)
GOOGLE_SERVICE_ACCOUNT_PATH=/app/security/google-service-account.json

# ── Apple Sign-In (.p8 key file mounted from ./security/) ─────────────────────
APPLE_CLIENT_ID=com.callvcal.hariharibol
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY_PATH=/app/security/apple-signin-key.p8

# ── AI Providers ──────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=sk-proj-your_openai_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── Firebase / FCM (service account JSON mounted from ./security/) ─────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_PATH=/app/security/firebase-service-account.json

# ── Storage (S3) ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=ap-south-1
S3_BUCKET=hariharibol-prod
CDN_URL=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_SERVICE=resend
EMAIL_FROM=noreply@hariharibol.com
RESEND_API_KEY=re_your_resend_api_key

# ── Apple Push (APNs .p8 mounted from ./security/) ────────────────────────────
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_PRIVATE_KEY_PATH=/app/security/apns-key.p8
APNS_PRODUCTION=true

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://ec2-13-206-188-46.ap-south-1.compute.amazonaws.com:3000,https://hariharibol.com

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_PANEL_URL=http://ec2-13-206-188-46.ap-south-1.compute.amazonaws.com:3000
ADMIN_JWT_SECRET=CHANGE_ME_admin_secret_at_least_32_chars

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=log
