# ──────────────────────────────────────────────────────────────────────────────
# WEBSITE — production environment (lives at /var/www/server/website/.env)
# Copy this file to .env and fill in real values. NEVER commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# ── App (baked into the Next.js build at request time) ────────────────────────
# Backend REST API base URL (must be reachable from the user's browser).
NEXT_PUBLIC_API_URL=https://api.hariharibol.com/api/v1
NEXT_PUBLIC_APP_NAME=HariHariBol
NEXT_PUBLIC_APP_ENV=production
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Deploy: ECR / image ───────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=669054244226
# REGISTRY defaults to ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
# REGISTRY=669054244226.dkr.ecr.ap-south-1.amazonaws.com
IMAGE_TAG=latest
HOST_PORT=3000

# ── Deploy: container resource limits (t3.micro has 908MB RAM) ────────────────
WEB_MEM_LIMIT=450m
WEB_MEM_RESERVATION=200m
WEB_CPU_LIMIT=0.75
